<mxCell id="t" value="Lab-04 出海市场洞察日报 — 业务逻辑图" style="rounded=0;fillColor=#0f6e5d;strokeColor=none;fontColor=#ffffff;fontSize=18;fontStyle=1;align=center;verticalAlign=middle;html=1;whiteSpace=wrap;" vertex="1" parent="1"><mxGeometry x="20" y="20" width="1140" height="46" as="geometry"/></mxCell>
<mxCell id="goal" value="目标：每天自动生成「美妆护肤 × 北美」跨境出海洞察日报（聚焦单品类·单市场，稳定后再扩展）" style="rounded=1;fillColor=#0b4f43;strokeColor=none;fontColor=#ffffff;fontSize=13;fontStyle=1;align=center;verticalAlign=middle;html=1;whiteSpace=wrap;" vertex="1" parent="1"><mxGeometry x="320" y="86" width="560" height="48" as="geometry"/></mxCell>
