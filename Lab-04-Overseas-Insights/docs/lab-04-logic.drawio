<mxCell id="t" value="Lab-04 — 技术逻辑图（GitHub Actions + gh-aw 智能工作流 + Copilot Agent）" style="rounded=0;fillColor=#0f6e5d;strokeColor=none;fontColor=#ffffff;fontSize=18;fontStyle=1;align=center;verticalAlign=middle;html=1;whiteSpace=wrap;" vertex="1" parent="1"><mxGeometry x="20" y="20" width="1140" height="46" as="geometry"/></mxCell>
<mxCell id="trig" value="触发&#10;• schedule  cron 0 21 * * * (UTC) = 北京 05:00&#10;• workflow_dispatch（手动）" style="rounded=1;fillColor=#ede7f6;strokeColor=#5e35b1;fontColor=#3b2566;fontSize=12;align=left;verticalAlign=middle;html=1;whiteSpace=wrap;spacingLeft=8;" vertex="1" parent="1"><mxGeometry x="20" y="86" width="300" height="70" as="geometry"/></mxCell>
<mxCell id="job" value="GitHub Actions Job：agent（编译产物 overseas-insight.lock.yml）" style="rounded=1;fillColor=none;strokeColor=#9aa0a6;dashed=1;fontColor=#3c4043;fontSize=13;fontStyle=1;align=left;verticalAlign=top;html=1;whiteSpace=wrap;spacingLeft=10;spacingTop=8;" vertex="1" parent="1"><mxGeometry x="20" y="180" width="780" height="620" as="geometry"/></mxCell>
<mxCell id="s1" value="① Setup Python 3.11 + 安装依赖（httpx / feedparser / beautifulsoup4）" style="rounded=1;fillColor=#eef2f6;strokeColor=#5f6f80;fontColor=#27313a;fontSize=12;align=left;verticalAlign=middle;html=1;whiteSpace=wrap;spacingLeft=8;" vertex="1" parent="1"><mxGeometry x="48" y="220" width="724" height="42" as="geometry"/></mxCell>
<mxCell id="s2" value="② 前置抓取步骤  overseas_fetch_bestsellers.py（在 runner 上、防火墙之外）&#10;· ScraperAPI 渲染抓取 5 大电商畅销榜 → output/signals/bestsellers/*.txt&#10;· 解析 Amazon Top 产品 → 派生关键词 → Alibaba.com 搜供应商 → output/signals/sourcing/*.txt&#10;· 密钥 SCRAPER_API_KEY：step 级 secret + 日志脱敏，绝不进入 agent / LLM" style="rounded=1;fillColor=#fde9d9;strokeColor=#cf7a3a;fontColor=#7a3f12;fontSize=12;align=left;verticalAlign=middle;html=1;whiteSpace=wrap;spacingLeft=8;" vertex="1" parent="1"><mxGeometry x="48" y="276" width="724" height="120" as="geometry"/></mxCell>
<mxCell id="s3" value="③ Copilot Agent 执行（engine: copilot · claude-sonnet-4.6 · 防火墙沙箱）" style="rounded=1;fillColor=none;strokeColor=#9aa0a6;dashed=1;fontColor=#3c4043;fontSize=13;fontStyle=1;align=left;verticalAlign=top;html=1;whiteSpace=wrap;spacingLeft=10;spacingTop=8;" vertex="1" parent="1"><mxGeometry x="48" y="410" width="724" height="268" as="geometry"/></mxCell>
<mxCell id="ph" value="阶段流水线：0 规划 → 1 RSS基线抓取装载 → 1.5 深度研究 → 1.6 热销TOP5 + 1688/Alibaba供应链 → 2 聚类 → 3 洞察 → 4 渲染报告" style="rounded=1;fillColor=#e3f2ec;strokeColor=#0f6e5d;fontColor=#0b4f43;fontSize=12;align=left;verticalAlign=middle;html=1;whiteSpace=wrap;spacingLeft=8;" vertex="1" parent="1"><mxGeometry x="74" y="448" width="672" height="64" as="geometry"/></mxCell>
<mxCell id="art" value="中间产物落盘：raw_signals.json · clusters/hotspots.json · insights/insights.json · products/top_products.json · report.md" style="rounded=1;fillColor=#e3f2ec;strokeColor=#0f6e5d;fontColor=#0b4f43;fontSize=12;align=left;verticalAlign=middle;html=1;whiteSpace=wrap;spacingLeft=8;" vertex="1" parent="1"><mxGeometry x="74" y="522" width="672" height="56" as="geometry"/></mxCell>
<mxCell id="cn" value="全程经 MCP 工具调用（见右）。关键工程：工具一律传【文件路径】而非内联 JSON，结果写入 out_path，仅返回精简状态。" style="rounded=1;fillColor=#e3f2ec;strokeColor=#0f6e5d;fontColor=#0b4f43;fontSize=12;align=left;verticalAlign=middle;html=1;whiteSpace=wrap;spacingLeft=8;" vertex="1" parent="1"><mxGeometry x="74" y="588" width="672" height="70" as="geometry"/></mxCell>
<mxCell id="s4" value="④ safe-outputs → create-pull-request&#10;提交 output/report.md + frontend/report.md（PR 留痕）" style="rounded=1;fillColor=#eef2f6;strokeColor=#5f6f80;fontColor=#27313a;fontSize=12;align=left;verticalAlign=middle;html=1;whiteSpace=wrap;spacingLeft=8;" vertex="1" parent="1"><mxGeometry x="48" y="696" width="724" height="80" as="geometry"/></mxCell>
<mxCell id="mcp" value="MCP 工具（mcp-scripts · Python · *_or_fallback 兜底）" style="rounded=1;fillColor=none;strokeColor=#9aa0a6;dashed=1;fontColor=#3c4043;fontSize=13;fontStyle=1;align=left;verticalAlign=top;html=1;whiteSpace=wrap;spacingLeft=10;spacingTop=8;" vertex="1" parent="1"><mxGeometry x="830" y="180" width="330" height="300" as="geometry"/></mxCell>
<mxCell id="mcpl" value="• read_source_list — 读数据源清单&#10;• fetch_all_to_disk — 抓 RSS 基线落盘&#10;• load_articles_from_disk — 解析装载&#10;• cluster_or_fallback — 聚类校验/兜底&#10;• insight_or_fallback — 洞察校验/兜底&#10;• products_or_fallback — TOP5校验/兜底&#10;• render_report_or_fallback — 渲染报告&#10;• write_text_file — 写文件&#10;（参数走路径 + out_path 落盘，输出小）" style="rounded=1;fillColor=#eaf1fb;strokeColor=#3b5b92;fontColor=#243b63;fontSize=12;align=left;verticalAlign=top;html=1;whiteSpace=wrap;spacingLeft=8;spacingTop=6;" vertex="1" parent="1"><mxGeometry x="854" y="218" width="282" height="246" as="geometry"/></mxCell>
<mxCell id="ext" value="外部数据源&#10;• RSS Feeds：Glossy / WWD / Modern Retail / Beauty Independent&#10;• ScraperAPI 代理 → Amazon / Sephora / Ulta / Target / TikTok Shop + Alibaba.com&#10;• 1688.com：验证码拦截 → 仅附搜索链接（人工核价）" style="rounded=1;fillColor=#f6f5f2;strokeColor=#9aa0a6;fontColor=#3c4043;fontSize=12;align=left;verticalAlign=top;html=1;whiteSpace=wrap;spacingLeft=8;spacingTop=6;" vertex="1" parent="1"><mxGeometry x="830" y="500" width="330" height="140" as="geometry"/></mxCell>
<mxCell id="tok" value="关键工程 · Token 安全&#10;运行环境 25M「有效 token」硬上限（≈ 实际 token × ~10 倍）。&#10;传路径（网关单参 10KB 上限）+ 落盘 out_path + 精简返回 → 回合数↓、上下文重发↓ → 有效 token ≈ 5M。&#10;反爬 / 解析失败 → *_or_fallback 兜底 + 缺口标注。" style="rounded=1;fillColor=#fbf6ea;strokeColor=#b08a3e;fontColor=#5a4a1f;fontSize=12;align=left;verticalAlign=top;html=1;whiteSpace=wrap;spacingLeft=8;spacingTop=6;" vertex="1" parent="1"><mxGeometry x="830" y="660" width="330" height="140" as="geometry"/></mxCell>
