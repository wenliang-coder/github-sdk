<mxCell id="c1" value="RSS 行业媒体（基线）&#10;Glossy · WWD · Modern Retail · Beauty Independent" style="rounded=1;fillColor=#e3f2ec;strokeColor=#0f6e5d;fontColor=#0b4f43;fontSize=12;align=center;verticalAlign=middle;html=1;whiteSpace=wrap;" vertex="1" parent="1"><mxGeometry x="170" y="168" width="230" height="96" as="geometry"/></mxCell>
