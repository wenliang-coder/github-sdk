<mxCell id="c3" value="电商畅销榜（销量代理）&#10;Amazon · Sephora · Ulta · Target · TikTok Shop" style="rounded=1;fillColor=#e3f2ec;strokeColor=#0f6e5d;fontColor=#0b4f43;fontSize=12;align=center;verticalAlign=middle;html=1;whiteSpace=wrap;" vertex="1" parent="1"><mxGeometry x="654" y="168" width="230" height="96" as="geometry"/></mxCell>
<mxCell id="c4" value="1688 / Alibaba 供应链&#10;供应商 · 拿货价 · MOQ" style="rounded=1;fillColor=#e3f2ec;strokeColor=#0f6e5d;fontColor=#0b4f43;fontSize=12;align=center;verticalAlign=middle;html=1;whiteSpace=wrap;" vertex="1" parent="1"><mxGeometry x="896" y="168" width="264" height="96" as="geometry"/></mxCell>
<mxCell id="L2" value="②&#10;加工分析" style="rounded=1;fillColor=#0f6e5d;strokeColor=none;fontColor=#ffffff;fontSize=13;fontStyle=1;align=center;verticalAlign=middle;html=1;whiteSpace=wrap;" vertex="1" parent="1"><mxGeometry x="20" y="300" width="130" height="96" as="geometry"/></mxCell>
<mxCell id="a1" value="聚类热点话题&#10;跨源趋势 + 高信号单条" style="rounded=1;fillColor=#fff3e0;strokeColor=#b08a3e;fontColor=#6b5417;fontSize=12;align=center;verticalAlign=middle;html=1;whiteSpace=wrap;" vertex="1" parent="1"><mxGeometry x="170" y="300" width="230" height="96" as="geometry"/></mxCell>
<mxCell id="a2" value="生成洞察&#10;发生了什么 / 为什么重要 /&#10;影响谁 / 接下来怎么做" style="rounded=1;fillColor=#fff3e0;strokeColor=#b08a3e;fontColor=#6b5417;fontSize=12;align=center;verticalAlign=middle;html=1;whiteSpace=wrap;" vertex="1" parent="1"><mxGeometry x="412" y="300" width="230" height="96" as="geometry"/></mxCell>
<mxCell id="a3" value="提炼热销 TOP5&#10;排名·评分·评价数·价格·趋势" style="rounded=1;fillColor=#fff3e0;strokeColor=#b08a3e;fontColor=#6b5417;fontSize=12;align=center;verticalAlign=middle;html=1;whiteSpace=wrap;" vertex="1" parent="1"><mxGeometry x="654" y="300" width="230" height="96" as="geometry"/></mxCell>
<mxCell id="a4" value="供应商匹配&#10;+ 预估毛利 + 合规要点" style="rounded=1;fillColor=#fff3e0;strokeColor=#b08a3e;fontColor=#6b5417;fontSize=12;align=center;verticalAlign=middle;html=1;whiteSpace=wrap;" vertex="1" parent="1"><mxGeometry x="896" y="300" width="264" height="96" as="geometry"/></mxCell>
<mxCell id="L3" value="③&#10;产出报告&#10;(中文 Markdown)" style="rounded=1;fillColor=#0f6e5d;strokeColor=none;fontColor=#ffffff;fontSize=13;fontStyle=1;align=center;verticalAlign=middle;html=1;whiteSpace=wrap;" vertex="1" parent="1"><mxGeometry x="20" y="432" width="130" height="96" as="geometry"/></mxCell>
<mxCell id="o1" value="A. 热点话题&#10;+ 选品 / 营销洞察 + 风险合规" style="rounded=1;fillColor=#eaf1fb;strokeColor=#3b5b92;fontColor=#243b63;fontSize=12;align=center;verticalAlign=middle;html=1;whiteSpace=wrap;" vertex="1" parent="1"><mxGeometry x="170" y="432" width="315" height="96" as="geometry"/></mxCell>
<mxCell id="o2" value="B. 北美热销 TOP5 产品&#10;（真实电商榜单·销量代理指标）" style="rounded=1;fillColor=#eaf1fb;strokeColor=#3b5b92;fontColor=#243b63;fontSize=12;align=center;verticalAlign=middle;html=1;whiteSpace=wrap;" vertex="1" parent="1"><mxGeometry x="497" y="432" width="315" height="96" as="geometry"/></mxCell>
<mxCell id="o3" value="C. 供应链落地（逐产品）&#10;供应商 / 拿货价 / 毛利 / 合规 + 链接" style="rounded=1;fillColor=#eaf1fb;strokeColor=#3b5b92;fontColor=#243b63;fontSize=12;align=center;verticalAlign=middle;html=1;whiteSpace=wrap;" vertex="1" parent="1"><mxGeometry x="824" y="432" width="336" height="96" as="geometry"/></mxCell>
<mxCell id="L4" value="④&#10;发布交付" style="rounded=1;fillColor=#0f6e5d;strokeColor=none;fontColor=#ffffff;fontSize=13;fontStyle=1;align=center;verticalAlign=middle;html=1;whiteSpace=wrap;" vertex="1" parent="1"><mxGeometry x="20" y="564" width="130" height="96" as="geometry"/></mxCell>
<mxCell id="p1" value="GitHub Pages 优雅网页&#10;…github.io/github-sdk/overseas/" style="rounded=1;fillColor=#f3e8f7;strokeColor=#7a4f8a;fontColor=#4a2d57;fontSize=12;align=center;verticalAlign=middle;html=1;whiteSpace=wrap;" vertex="1" parent="1"><mxGeometry x="170" y="564" width="315" height="96" as="geometry"/></mxCell>
<mxCell id="p2" value="PR 存档&#10;（safe-outputs 留痕）" style="rounded=1;fillColor=#f3e8f7;strokeColor=#7a4f8a;fontColor=#4a2d57;fontSize=12;align=center;verticalAlign=middle;html=1;whiteSpace=wrap;" vertex="1" parent="1"><mxGeometry x="497" y="564" width="250" height="96" as="geometry"/></mxCell>
<mxCell id="p3" value="节奏：每日定时（北京 05:00）自动运行&#10;+ 可手动触发" style="rounded=1;fillColor=#f3e8f7;strokeColor=#7a4f8a;fontColor=#4a2d57;fontSize=12;align=center;verticalAlign=middle;html=1;whiteSpace=wrap;" vertex="1" parent="1"><mxGeometry x="759" y="564" width="401" height="96" as="geometry"/></mxCell>
<mxCell id="hon" value="诚实口径 / 数据边界（写进报告，不夸大）&#10;• 免费抓取拿不到精确销量(件数/GMV) → 用「排名 + 评分 + 评价数 + 趋势」作销量代理；精确销量需付费工具(Jungle Scout/Helium 10)&#10;• 部分电商为 SPA/强反爬，1688.com 被验证码拦截 → 据实标注缺口，用新闻信号兜底，并附 1688 搜索链接供人工核价&#10;• 预估毛利 = (美国零售价 − 拿货价) / 零售价，为粗估，未计头程物流/关税/平台佣金FBA/广告/退货（净利约为其 30–50%）&#10;• 合规为「入市要求提示」（FDA 注册 + MoCRA + INCI 标签 等），非对供应商资质的背书" style="rounded=1;fillColor=#fbf6ea;strokeColor=#b08a3e;fontColor=#5a4a1f;fontSize=12;align=left;verticalAlign=top;html=1;whiteSpace=wrap;spacingLeft=8;spacingTop=6;" vertex="1" parent="1"><mxGeometry x="20" y="690" width="1140" height="130" as="geometry"/></mxCell>
